BoxLayout:
    orientation: 'horizontal'

    BoxLayout:
        orientation: 'vertical'
        size_hint_x: 0.3
        Label:
            text: 'Sort by:'
            size_hint_y: 1.3
        Spinner:
            id: sort_spinner
            text: app.current_spinner
            values: ["Title", "Author", "Pages", "Completed"]
            on_text:
                app.current_spinner = self.text
                app.handle_sort(self.text)

        Label:
            text: 'Add book...'
        Label:
            text: 'Title:'
        TextInput:
            id: input_title
        Label:
            text: 'Author:'
        TextInput:
            id: input_author
        Label:
            text: 'Pages:'
        TextInput:
            id: input_pages
        Button:
            text: 'Add Book'
            on_press: app.add_book()
            size_hint_y: 1.5
        Button:
            text: 'Clear'
            on_press: app.handle_clear()
            size_hint_y: 1.5

    BoxLayout:
        orientation: 'vertical'
        Label:
            size_hint_y: 0.1
            text: app.page_count_text
        BoxLayout:
            id: entries_box
            orientation: 'vertical'
        Label:
            size_hint_y: 0.1
            text: app.bottom_label_text
